<Window x:Class="Compass.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Compass" 
        SizeToContent="Height" Width="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False"
        TextOptions.TextFormattingMode="Display"
        FontFamily="Segoe UI Variable Display, Segoe UI">

    <Window.Resources>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <EventSetter Event="PreviewMouseLeftButtonUp" Handler="SearchResultList_PreviewMouseLeftButtonUp"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" 
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="6"
                                Padding="8,5"
                                Margin="2">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="MainBorder" Margin="30" Background="#E61C1C1C" CornerRadius="12" BorderBrush="#2D2D2D" BorderThickness="1" Opacity="1.0" IsHitTestVisible="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.5" Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <!-- Spotlight View -->
            <StackPanel x:Name="SpotlightView">
                <Grid>
                    <ScrollViewer x:Name="ChatScroll" Margin="15,0,15,0" MaxHeight="450" VerticalScrollBarVisibility="Hidden" Opacity="0" Visibility="Collapsed">
                        <ScrollViewer.LayoutTransform>
                            <ScaleTransform x:Name="ChatScale" ScaleY="0"/>
                        </ScrollViewer.LayoutTransform>
                        <StackPanel x:Name="ChatPanel" VerticalAlignment="Bottom"/>
                    </ScrollViewer>
                    <Grid x:Name="ExitChatArrow" MouseLeftButtonUp="ExitChatBtn_Click" Visibility="Collapsed" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="15" Background="Transparent" Cursor="Hand">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Opacity" Value="0.6"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1.0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Path Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" Fill="#666666" Stretch="Uniform" Width="24" Height="24" IsHitTestVisible="False"/>
                    </Grid>
                    <Grid x:Name="ClearChatBtn" MouseLeftButtonUp="ClearChatBtn_Click" Visibility="Collapsed" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="15" Background="Transparent" Cursor="Hand" ToolTip="Clear Chat">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Opacity" Value="0.6"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1.0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="#666666" Stretch="Uniform" Width="20" Height="20" IsHitTestVisible="False"/>
                    </Grid>
                </Grid>

                <Border Background="#151515" CornerRadius="8" Padding="12" Margin="15">
                    <Grid>
                        <TextBlock x:Name="PlaceholderText" Text="Ask Gemini or search apps..." Foreground="#666666" FontSize="22" VerticalAlignment="Center" Margin="2,0,0,0" IsHitTestVisible="False"/>
                        <TextBox x:Name="InputBox" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="22" VerticalContentAlignment="Center" PreviewKeyDown="InputBox_PreviewKeyDown" TextChanged="InputBox_TextChanged"/>
                        <Border x:Name="ResumeChatIndicator" HorizontalAlignment="Right" VerticalAlignment="Center" Background="#222" CornerRadius="4" Padding="8,4" Margin="0,0,5,0" Cursor="Hand" Visibility="Collapsed" MouseLeftButtonUp="ResumeChat_Click">
                            <TextBlock Text="Resume Chat →" Foreground="#666" FontSize="12"/>
                        </Border>
                    </Grid>
                </Border>

                <ListBox x:Name="SearchResultList" Margin="15,0,15,15" Background="Transparent" Foreground="White" BorderThickness="0" Visibility="Collapsed" IsHitTestVisible="True">
                    <ListBox.LayoutTransform>
                        <ScaleTransform x:Name="SearchScale" ScaleY="0"/>
                    </ListBox.LayoutTransform>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="32" Height="32" Margin="0,0,15,0">
                                    <Image Source="{Binding AppIcon}"/>
                                    <Path Data="{Binding GeometryIcon}" Fill="#4CC2FF" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                                <TextBlock Text="{Binding AppName}" VerticalAlignment="Center" FontSize="16"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

            <!-- Manager View -->
            <StackPanel x:Name="ManagerView" Visibility="Collapsed" Margin="20">
                <Button Content="← Back" Click="ExitManagerMode_Click" HorizontalAlignment="Left" Background="Transparent" Foreground="#AAAAAA" BorderThickness="0" Margin="0,0,0,15" Cursor="Hand"/>

                <TabControl x:Name="SettingsTabs" Background="Transparent" BorderThickness="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border Name="Border" BorderThickness="0,0,0,2" BorderBrush="Transparent" Margin="0,0,10,0" Padding="10,5">
                                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="10,2"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#4CC2FF" />
                                                <Setter Property="Foreground" Value="White" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="False">
                                                <Setter Property="Foreground" Value="#888888" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>

                    <TabItem Header="General">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="350" Margin="0,15,0,0">
                            <StackPanel>
                                <TextBlock Text="Compass Settings" FontSize="20" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,15"/>

                                <TextBlock Text="Gemini API Key" Foreground="#CCCCCC" Margin="0,0,0,5" FontWeight="SemiBold"/>
                                <PasswordBox x:Name="ApiKeyBox" Background="#151515" Foreground="White" BorderBrush="#333" BorderThickness="1" Padding="8" Margin="0,0,0,15"/>

                                <TextBlock Text="System Instructions" Foreground="#CCCCCC" Margin="0,0,0,5" FontWeight="SemiBold"/>
                                <TextBox x:Name="SystemPromptBox" TextWrapping="Wrap" AcceptsReturn="True" Height="60" Background="#151515" Foreground="White" BorderBrush="#333" BorderThickness="1" Padding="8" Margin="0,0,0,15" VerticalScrollBarVisibility="Auto"/>

                                <TextBlock Text="AI Model" Foreground="#CCCCCC" Margin="0,0,0,5" FontWeight="SemiBold"/>
                                <ComboBox x:Name="ModelComboBox" Margin="0,0,0,15" Foreground="White" BorderThickness="0" SelectionChanged="ModelComboBox_SelectionChanged">
                                    <ComboBox.Template>
                                        <ControlTemplate TargetType="ComboBox">
                                            <Grid>
                                                <ToggleButton x:Name="ToggleButton" Focusable="false" ClickMode="Press" HorizontalContentAlignment="Left">
                                                    <ToggleButton.Template>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border x:Name="Border" CornerRadius="4" Background="#151515" BorderBrush="#333" BorderThickness="1" Padding="8">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Path x:Name="Arrow" Grid.Column="1" Fill="#888" HorizontalAlignment="Right" VerticalAlignment="Center" Data="M0,0 L4,4 L8,0 Z"/>
                                                                </Grid>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </ToggleButton.Template>
                                                </ToggleButton>
                                                <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="10,0,25,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                                <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                                    <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                                        <Border x:Name="DropDownBorder" Background="#151515" BorderThickness="1" BorderBrush="#333" CornerRadius="4"/>
                                                        <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                                        </ScrollViewer>
                                                    </Grid>
                                                </Popup>
                                            </Grid>
                                        </ControlTemplate>
                                    </ComboBox.Template>
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Padding" Value="8"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ComboBoxItem">
                                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#333333"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#444444"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                </ComboBox>

                                <TextBlock Text="Manage Models" Foreground="#CCCCCC" Margin="0,0,0,5" FontWeight="SemiBold"/>
                                <ItemsControl x:Name="ModelsList" Margin="0,0,0,10">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#252525" CornerRadius="4" Margin="0,0,0,5" Padding="8">
                                                <Grid>
                                                    <TextBlock Text="{Binding}" Foreground="White" VerticalAlignment="Center"/>
                                                    <Button Content="Delete" Click="DeleteModel_Click" HorizontalAlignment="Right" Background="#3A1515" Foreground="#FF6666" BorderThickness="0" Padding="8,4" Cursor="Hand" FontSize="10"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="NewModelBox" Padding="8" Background="#151515" Foreground="White" BorderBrush="#333" BorderThickness="1"/>
                                    <Button Grid.Column="1" Content="Add Model" Click="AddModel_Click" Margin="10,0,0,0" Padding="15,8" Background="#2B579A" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                </Grid>

                                <CheckBox x:Name="StartupCheck" Content="Launch at Startup" Foreground="White" Margin="0,0,0,20" Checked="StartupCheck_Changed" Unchecked="StartupCheck_Changed"/>

                                <TextBlock Text="Window Opacity" Foreground="#CCCCCC" Margin="0,0,0,5" FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <Slider x:Name="OpacitySlider" Minimum="0.1" Maximum="1.0" Value="1.0" Width="200" ValueChanged="OpacitySlider_ValueChanged"/>
                                    <TextBlock Text="{Binding Value, ElementName=OpacitySlider, StringFormat={}{0:P0}}" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>

                                <Button Content="Save Settings" Click="SaveApiKey_Click" Padding="15,8" Background="#2B579A" Foreground="White" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Shortcuts">
                        <StackPanel Margin="0,15,0,0">
                            <TextBlock Text="Manage Shortcuts" FontSize="20" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,15"/>
                            <ScrollViewer MaxHeight="250" Margin="0,0,0,15" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="ShortcutsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#252525" CornerRadius="6" Margin="0,0,0,8" Padding="10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Keyword}" Foreground="#4CC2FF" FontWeight="Bold" FontSize="14"/>
                                                        <TextBlock Text="{Binding UrlTemplate}" Foreground="#888888" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="Delete" Click="DeleteShortcut_Click" Background="#3A1515" Foreground="#FF6666" BorderThickness="0" Padding="10,5" Margin="10,0,0,0" Cursor="Hand"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <TextBlock Text="Add New Shortcut" Foreground="#CCCCCC" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="NewKeywordBox" Margin="0,0,5,0" Padding="8" Background="#151515" Foreground="White" BorderBrush="#333" BorderThickness="1" />
                                <TextBox x:Name="NewUrlBox" Grid.Column="1" Margin="0,0,5,0" Padding="8" Background="#151515" Foreground="White" BorderBrush="#333" BorderThickness="1" />
                                <Button Grid.Column="2" Content="Add" Click="AddShortcut_Click" Padding="15,8" Background="#2B579A" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            </Grid>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Commands">
                        <StackPanel Margin="0,15,0,0">
                            <TextBlock Text="Manage AI Commands" FontSize="20" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,15"/>

                            <ScrollViewer MaxHeight="200" Margin="0,0,0,15" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="CommandsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#252525" CornerRadius="6" Margin="0,0,0,8" Padding="10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding TriggerName}" Foreground="#4CC2FF" FontWeight="Bold" FontSize="14"/>
                                                        <TextBlock Text="{Binding Description}" Foreground="#888888" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="Delete" Click="DeleteCommand_Click" Background="#3A1515" Foreground="#FF6666" BorderThickness="0" Padding="10,5" Margin="10,0,0,0" Cursor="Hand"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <TextBlock Text="Create New Command" Foreground="#CCCCCC" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <TextBlock Text="Trigger Name (e.g., 'wifi off')" Foreground="#888888" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox x:Name="NewCommandTrigger" Margin="0,0,0,10" Padding="8" Background="#151515" Foreground="White" BorderBrush="#333" BorderThickness="1" />

                            <TextBlock Text="What should it do? (Natural Language)" Foreground="#888888" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox x:Name="NewCommandIntent" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10" Padding="8" Background="#151515" Foreground="White" BorderBrush="#333" BorderThickness="1" />

                            <Button Content="Generate Command" Click="CreateCommand_Click" Padding="15,8" Background="#2B579A" Foreground="White" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </StackPanel>
        </Grid>
    </Border>
</Window>