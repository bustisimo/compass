                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="Smart Model Routing" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="13"/>
                                                    <TextBlock Text="Auto-select faster or more capable models per query" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <CheckBox x:Name="SmartRoutingCheck" Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource ToggleSwitchStyle}" Checked="SmartRoutingCheck_Changed" Unchecked="SmartRoutingCheck_Changed"/>
                                            </Grid>
                                        </Border>

                                        <StackPanel x:Name="RoutingModelsPanel" Visibility="Collapsed" Margin="0,0,0,8">
                                            <TextBlock Text="Fast Model (simple queries)" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6" FontSize="12"/>
                                            <ComboBox x:Name="FastModelComboBox" Margin="0,0,0,10" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0" SelectionChanged="FastModelComboBox_SelectionChanged">
                                                <ComboBox.Template>
                                                    <ControlTemplate TargetType="ComboBox">
                                                        <Grid>
                                                            <ToggleButton Focusable="false" ClickMode="Press" HorizontalContentAlignment="Left" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                                                <ToggleButton.Template>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border CornerRadius="8" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" Padding="10,8">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <Path Grid.Column="1" Fill="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Data="M0,0 L4,4 L8,0 Z"/>
                                                                            </Grid>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </ToggleButton.Template>
                                                            </ToggleButton>
                                                            <ContentPresenter IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" Margin="12,0,28,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                                                <Grid SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                                                    <Border Background="{DynamicResource SurfaceBrush}" BorderThickness="1" BorderBrush="{DynamicResource InputBorderBrush}" CornerRadius="8" Margin="0,4,0,0"/>
                                                                    <ScrollViewer Margin="4,10,4,6" SnapsToDevicePixels="True">
                                                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                                                    </ScrollViewer>
                                                                </Grid>
                                                            </Popup>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </ComboBox.Template>
                                                <ComboBox.ItemContainerStyle>
                                                    <Style TargetType="ComboBoxItem">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                        <Setter Property="Padding" Value="10,8"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ComboBoxItem">
                                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="6" Margin="2">
                                                                        <ContentPresenter/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsSelected" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ComboBox.ItemContainerStyle>
                                            </ComboBox>

                                            <TextBlock Text="Power Model (complex queries)" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,6" FontSize="12"/>
                                            <ComboBox x:Name="PowerModelComboBox" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0" SelectionChanged="PowerModelComboBox_SelectionChanged">
                                                <ComboBox.Template>
                                                    <ControlTemplate TargetType="ComboBox">
                                                        <Grid>
                                                            <ToggleButton Focusable="false" ClickMode="Press" HorizontalContentAlignment="Left" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                                                <ToggleButton.Template>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border CornerRadius="8" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" Padding="10,8">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <Path Grid.Column="1" Fill="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Data="M0,0 L4,4 L8,0 Z"/>
                                                                            </Grid>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </ToggleButton.Template>
                                                            </ToggleButton>
                                                            <ContentPresenter IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" Margin="12,0,28,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                                                <Grid SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                                                    <Border Background="{DynamicResource SurfaceBrush}" BorderThickness="1" BorderBrush="{DynamicResource InputBorderBrush}" CornerRadius="8" Margin="0,4,0,0"/>
                                                                    <ScrollViewer Margin="4,10,4,6" SnapsToDevicePixels="True">
                                                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                                                    </ScrollViewer>
                                                                </Grid>
                                                            </Popup>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </ComboBox.Template>
                                                <ComboBox.ItemContainerStyle>
                                                    <Style TargetType="ComboBoxItem">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                        <Setter Property="Padding" Value="10,8"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ComboBoxItem">
                                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="6" Margin="2">
                                                                        <ContentPresenter/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsSelected" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ComboBox.ItemContainerStyle>
                                            </ComboBox>
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Shortcuts">
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="Web shortcuts" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                            <TextBlock Text="Type a keyword in the search bar to open its URL. Use {query} in the URL template for search terms." Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,15"/>
                            <TextBlock x:Name="ShortcutsEmptyState" Text="No shortcuts yet. Add one below."
                                       Foreground="{DynamicResource TextTertiaryBrush}" FontSize="13"
                                       HorizontalAlignment="Center" Margin="0,10,0,10" Visibility="Collapsed"/>
                            <ScrollViewer MaxHeight="250" Margin="0,0,0,15" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="ShortcutsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="0,0,0,8" Padding="14,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Keyword}" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="14"/>
                                                        <TextBlock Text="{Binding UrlTemplate}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="Delete" Click="DeleteShortcut_Click" Margin="10,0,0,0" Style="{StaticResource DangerButtonStyle}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <TextBlock Text="Add New Shortcut" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" FontWeight="SemiBold" FontSize="13"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="NewKeywordBox" Margin="0,0,8,0" Style="{StaticResource ModernTextBox}"/>
                                <TextBox x:Name="NewUrlBox" Grid.Column="1" Margin="0,0,8,0" Style="{StaticResource ModernTextBox}"/>
                                <Button Grid.Column="2" Content="Add" Click="AddShortcut_Click" Style="{StaticResource SettingsButtonStyle}" MinWidth="70"/>
                            </Grid>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Commands">
                        <StackPanel Margin="0,12,0,0">
                            <TextBlock Text="AI commands" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                            <TextBlock Text="AI-generated PowerShell commands triggered by natural language. Type the trigger phrase in the search bar to run." Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>

                            <TextBlock x:Name="CommandsEmptyState" Text="No commands yet. Create one below."
                                       Foreground="{DynamicResource TextTertiaryBrush}" FontSize="13"
                                       HorizontalAlignment="Center" Margin="0,10,0,10" Visibility="Collapsed"/>
                            <ScrollViewer MaxHeight="200" Margin="0,0,0,15" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="CommandsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="0,0,0,8" Padding="14,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding TriggerName}" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="14"/>
                                                        <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="Delete" Click="DeleteCommand_Click" Margin="10,0,0,0" Style="{StaticResource DangerButtonStyle}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <TextBlock Text="Create New Command" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Text="Trigger Name (e.g., 'wifi off')" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox x:Name="NewCommandTrigger" Margin="0,0,0,12" Style="{StaticResource ModernTextBox}"/>

                            <TextBlock Text="What should it do? (Natural Language)" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox x:Name="NewCommandIntent" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,12" Style="{StaticResource ModernTextBox}"/>

                            <Button Content="Generate Command" Click="CreateCommand_Click" HorizontalAlignment="Left" Style="{StaticResource SettingsButtonStyle}"/>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Widgets">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="Widget panel" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                                <TextBlock Text="Widgets appear below the search bar when idle. Reorder, enable, or create custom widgets below." Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16,12" Margin="0,0,0,15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Enable Widgets" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Text="Show widget panel when Compass is idle" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="WidgetsEnabledCheck" Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource ToggleSwitchStyle}" Checked="WidgetsEnabledCheck_Changed" Unchecked="WidgetsEnabledCheck_Changed"/>
                                    </Grid>
                                </Border>

                                <TextBlock Text="Installed Widgets" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Drag widgets on the main screen to reorder them." Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,0,0,8"/>
                                <ItemsControl x:Name="WidgetsList" Margin="0,0,0,15">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="0,0,0,8" Padding="14,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Widget name and description -->
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="13"/>
                                                        <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                    </StackPanel>

                                                    <!-- Delete button (only for custom widgets) -->
                                                    <Button Grid.Column="1" Content="Delete" Tag="{Binding Id}" Click="DeleteWidget_Click" Padding="8,4" FontSize="10" Margin="0,0,8,0" VerticalAlignment="Center" Visibility="{Binding DeleteVisibility}" Style="{StaticResource DangerButtonStyle}"/>

                                                    <!-- Enabled toggle -->
                                                    <CheckBox Grid.Column="2" VerticalAlignment="Center" IsChecked="{Binding IsEnabled, Mode=TwoWay}" Style="{StaticResource ToggleSwitchStyle}" Tag="{Binding Id}" Checked="WidgetToggle_Changed" Unchecked="WidgetToggle_Changed"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Create Custom Widget (AI)" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,10,0,6" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock Text="Widget Name" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="NewWidgetName" Margin="0,0,0,12" Style="{StaticResource ModernTextBox}"/>
                                <TextBlock Text="Describe the widget (what should it display?)" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="NewWidgetDescription" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,12" Style="{StaticResource ModernTextBox}"/>
                                <Button Content="Generate Widget" Click="CreateWidget_Click" HorizontalAlignment="Left" Style="{StaticResource SettingsButtonStyle}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Personalization">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400" Margin="0,15,0,0">
                            <StackPanel>

                                <!-- A. AI Design Studio (hero section) -->
                                <Border CornerRadius="12" Padding="20" Margin="0,0,0,20" BorderThickness="1" BorderBrush="{DynamicResource AccentBrush}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1A1A2E" Offset="0"/>
                                            <GradientStop Color="#16213E" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <TextBlock Text="AI Design Studio" Foreground="{DynamicResource AccentBrush}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBlock Text="Describe your ideal look and let AI redesign your Compass" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" Margin="0,0,0,14"/>

                                        <TextBox x:Name="PersonalizationInputBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10" Style="{StaticResource ModernTextBox}" VerticalScrollBarVisibility="Auto"/>

                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Content="Generate &amp; Preview" Click="GeneratePersonalizationPreview_Click" HorizontalAlignment="Left" Style="{StaticResource SettingsButtonStyle}"/>
                                            <Button Grid.Column="2" Content="Reset to Default" Click="ResetPersonalization_Click" Style="{StaticResource PillButtonStyle}" Padding="14,8"/>
                                        </Grid>

                                        <!-- Generation progress indicator -->
                                        <Border x:Name="GenerationProgressPanel" Visibility="Collapsed" CornerRadius="8" Padding="14,10" Margin="0,0,0,10">
                                            <Border.Background>
                                                <SolidColorBrush Color="#0FFFFFFF"/>
                                            </Border.Background>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="GenerationSpinner" Text="◐" FontSize="16" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock x:Name="GenerationStatusText" Text="Designing your theme..." FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <TextBlock x:Name="GenerationSubText" Text="AI is crafting colors, layout, and style" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Text="Quick styles:" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,0,0,6"/>
                                        <WrapPanel>
                                            <Button Content="Cyberpunk" Tag="Dark theme with neon cyan and purple accents, sharp corners" Click="QuickStyle_Click" Margin="0,0,8,6" Style="{StaticResource PillButtonStyle}"/>
                                            <Button Content="Minimal Light" Tag="Clean white theme with gray text, thin borders, no animations" Click="QuickStyle_Click" Margin="0,0,8,6" Style="{StaticResource PillButtonStyle}"/>
                                            <Button Content="Forest" Tag="Dark green theme with nature tones and soft rounded corners" Click="QuickStyle_Click" Margin="0,0,8,6" Style="{StaticResource PillButtonStyle}"/>
                                            <Button Content="Ocean" Tag="Deep blue theme with light blue accents" Click="QuickStyle_Click" Margin="0,0,8,6" Style="{StaticResource PillButtonStyle}"/>
                                        </WrapPanel>

                                        <!-- Preview Section (nested within hero) -->
                                        <Border x:Name="PreviewSection" Background="{DynamicResource CardBrush}" CornerRadius="10" Padding="16" Margin="0,10,0,0" Visibility="Collapsed">
                                            <StackPanel>
                                                <TextBlock Text="Preview of Changes" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                                                <TextBlock Text="Proposed Changes:" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,5" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="PreviewChangesText" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,15"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="Accept Changes" Click="AcceptPersonalization_Click" Style="{StaticResource SettingsButtonStyle}" Margin="0,0,10,0"/>
                                                    <Button Content="Reject" Click="RejectPersonalization_Click" Style="{StaticResource DangerButtonStyle}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- B. Collapsible manual sections -->

                                <!-- 1. Theme & Colors -->
                                <Expander Header="Theme &amp; Colors" IsExpanded="True" Style="{StaticResource ModernExpander}">
                                    <StackPanel>
                                        <TextBlock Text="Built-in Themes" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,0,0,6"/>
                                        <WrapPanel Margin="0,0,0,16">
                                            <Button Content="Dark" Tag="Dark" Click="BuiltInTheme_Click" Margin="0,0,8,8" Style="{StaticResource PillButtonStyle}"/>
                                            <Button Content="Light" Tag="Light" Click="BuiltInTheme_Click" Margin="0,0,8,8" Style="{StaticResource PillButtonStyle}"/>
                                            <Button Content="High Contrast" Tag="High Contrast" Click="BuiltInTheme_Click" Margin="0,0,8,8" Style="{StaticResource PillButtonStyle}"/>
                                        </WrapPanel>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>

                                            <StackPanel Margin="0,0,8,10">
                                                <TextBlock Text="Primary" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                                <Grid>
                                                    <Border x:Name="PrimaryColorSwatch" Width="36" Height="36" CornerRadius="8" Background="#1C1C1C" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" HorizontalAlignment="Left" Cursor="Hand" MouseLeftButtonUp="ColorSwatch_Click" Tag="Primary"/>
                                                    <TextBox x:Name="PrimaryColorInput" Text="#1C1C1C" Width="90" Margin="44,0,0,0" HorizontalAlignment="Left" Style="{StaticResource ModernTextBox}" FontSize="12" Padding="6,6" LostFocus="ColorInput_LostFocus" Tag="Primary"/>
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="0,0,8,10">
                                                <TextBlock Text="Accent" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                                <Grid>
                                                    <Border x:Name="AccentColorSwatch" Width="36" Height="36" CornerRadius="8" Background="#4CC2FF" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" HorizontalAlignment="Left" Cursor="Hand" MouseLeftButtonUp="ColorSwatch_Click" Tag="Accent"/>
                                                    <TextBox x:Name="AccentColorInput" Text="#4CC2FF" Width="90" Margin="44,0,0,0" HorizontalAlignment="Left" Style="{StaticResource ModernTextBox}" FontSize="12" Padding="6,6" LostFocus="ColorInput_LostFocus" Tag="Accent"/>
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Margin="0,0,0,10">
                                                <TextBlock Text="Border" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                                <Grid>
                                                    <Border x:Name="BorderColorSwatch" Width="36" Height="36" CornerRadius="8" Background="#2D2D2D" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" HorizontalAlignment="Left" Cursor="Hand" MouseLeftButtonUp="ColorSwatch_Click" Tag="Border"/>
                                                    <TextBox x:Name="BorderColorInput" Text="#2D2D2D" Width="90" Margin="44,0,0,0" HorizontalAlignment="Left" Style="{StaticResource ModernTextBox}" FontSize="12" Padding="6,6" LostFocus="ColorInput_LostFocus" Tag="Border"/>
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Margin="0,0,8,10">
                                                <TextBlock Text="Surface (optional)" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                                <Grid>
                                                    <Border x:Name="SecondaryColorSwatch" Width="36" Height="36" CornerRadius="8" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" HorizontalAlignment="Left" Cursor="Hand" MouseLeftButtonUp="ColorSwatch_Click" Tag="Secondary"/>
                                                    <TextBox x:Name="SecondaryColorInput" Text="" Width="90" Margin="44,0,0,0" HorizontalAlignment="Left" Style="{StaticResource ModernTextBox}" FontSize="12" Padding="6,6" LostFocus="ColorInput_LostFocus" Tag="Secondary"/>
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,8,10">
                                                <TextBlock Text="Text (optional)" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                                <Grid>
                                                    <Border x:Name="TextColorSwatch" Width="36" Height="36" CornerRadius="8" Background="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" HorizontalAlignment="Left" Cursor="Hand" MouseLeftButtonUp="ColorSwatch_Click" Tag="Text"/>
                                                    <TextBox x:Name="TextColorInput" Text="" Width="90" Margin="44,0,0,0" HorizontalAlignment="Left" Style="{StaticResource ModernTextBox}" FontSize="12" Padding="6,6" LostFocus="ColorInput_LostFocus" Tag="Text"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Expander>

                                <!-- 2. Background & Effects -->
                                <Expander Header="Background &amp; Effects" IsExpanded="False" Style="{StaticResource ModernExpander}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock Text="Background Type" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="BackgroundTypeCombo" SelectionChanged="BackgroundTypeCombo_SelectionChanged" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0">
                                                    <ComboBox.Template>
                                                        <ControlTemplate TargetType="ComboBox">
                                                            <Grid>
                                                                <ToggleButton Focusable="false" ClickMode="Press" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                                                    <ToggleButton.Template>
                                                                        <ControlTemplate TargetType="ToggleButton">
                                                                            <Border CornerRadius="8" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" Padding="8,6">
                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <Path Grid.Column="1" Fill="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Data="M0,0 L4,4 L8,0 Z"/>
                                                                                </Grid>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </ToggleButton.Template>
                                                                </ToggleButton>
                                                                <ContentPresenter IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" Margin="10,0,24,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                                <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                                                    <Grid SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                                                        <Border Background="{DynamicResource SurfaceBrush}" BorderThickness="1" BorderBrush="{DynamicResource InputBorderBrush}" CornerRadius="8" Margin="0,4,0,0"/>
                                                                        <ScrollViewer Margin="4,10,4,6">
                                                                            <StackPanel IsItemsHost="True"/>
                                                                        </ScrollViewer>
                                                                    </Grid>
                                                                </Popup>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </ComboBox.Template>
                                                    <ComboBox.ItemContainerStyle>
                                                        <Style TargetType="ComboBoxItem">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                            <Setter Property="Padding" Value="8,6"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ComboBoxItem">
                                                                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}" CornerRadius="6" Margin="2">
                                                                            <ContentPresenter/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </ComboBox.ItemContainerStyle>
                                                </ComboBox>
                                            </StackPanel>

                                        </Grid>

                                        <!-- Gradient Colors -->
                                        <StackPanel x:Name="GradientColorsPanel" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Margin="0,0,8,0">
                                                    <TextBlock Text="Gradient Start" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                                    <TextBox x:Name="GradientStartInput" Style="{StaticResource ModernTextBox}" FontSize="12" Padding="6,6" LostFocus="GradientColorInput_LostFocus"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Gradient End" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                                    <TextBox x:Name="GradientEndInput" Style="{StaticResource ModernTextBox}" FontSize="12" Padding="6,6" LostFocus="GradientColorInput_LostFocus"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Gradient Angle -->
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Text="Gradient Angle" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Slider x:Name="GradientAngleSlider" Minimum="0" Maximum="360" Value="135" Width="80" Style="{StaticResource ModernSlider}" ValueChanged="GradientAngleSlider_ValueChanged"/>
                                                <TextBlock Text="{Binding Value, ElementName=GradientAngleSlider, StringFormat={}{0:0}°}" Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="6,0,0,0" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Background Image Controls -->
                                        <StackPanel x:Name="BackgroundImagePanel" Visibility="Collapsed" Margin="0,4,0,8">
                                            <TextBlock Text="Background Image" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,0,0,6"/>
                                            <Border x:Name="BackgroundImagePreview" Visibility="Collapsed" CornerRadius="6" ClipToBounds="True" Width="120" Height="70" HorizontalAlignment="Left" Margin="0,0,0,6">
                                                <Image x:Name="BackgroundImageThumbnail" Stretch="UniformToFill"/>
                                            </Border>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <Button Content="Pick Image" Click="PickBackgroundImage_Click" Style="{StaticResource SettingsButtonStyle}" Padding="10,5" FontSize="11"/>
                                                <Button x:Name="RemoveBackgroundImageBtn" Content="Remove" Click="RemoveBackgroundImage_Click" Style="{StaticResource DangerButtonStyle}" Padding="10,5" FontSize="11" Margin="8,0,0,0" Visibility="Collapsed"/>
                                            </StackPanel>
                                            <TextBlock Text="Image Opacity" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Slider x:Name="ImageOpacitySlider" Minimum="0.05" Maximum="1.0" Value="0.3" Width="120" Style="{StaticResource ModernSlider}" ValueChanged="ImageOpacitySlider_ValueChanged"/>
                                                <TextBlock Text="{Binding Value, ElementName=ImageOpacitySlider, StringFormat={}{0:P0}}" Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="6,0,0,0" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>


                                    </StackPanel>
                                </Expander>

                                <!-- 3. Layout & Shape -->
                                <Expander Header="Layout &amp; Shape" IsExpanded="False" Style="{StaticResource ModernExpander}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Border Radius" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Slider x:Name="BorderRadiusSlider" Minimum="0" Maximum="24" Value="12" Width="80" Style="{StaticResource ModernSlider}" ValueChanged="BorderRadiusSlider_ValueChanged"/>
                                                <TextBlock Text="{Binding Value, ElementName=BorderRadiusSlider, StringFormat={}{0:0}px}" Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="6,0,0,0" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                            <TextBlock Text="Window Width" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Slider x:Name="WindowWidthSlider" Minimum="500" Maximum="1000" Value="700" Width="80" Style="{StaticResource ModernSlider}" ValueChanged="WindowWidthSlider_ValueChanged"/>
                                                <TextBlock Text="{Binding Value, ElementName=WindowWidthSlider, StringFormat={}{0:0}}" Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="6,0,0,0" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Border Thickness" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Slider x:Name="BorderThicknessSlider" Minimum="0" Maximum="4" Value="1" Width="80" Style="{StaticResource ModernSlider}" ValueChanged="BorderThicknessSlider_ValueChanged"/>
                                                <TextBlock Text="{Binding Value, ElementName=BorderThicknessSlider, StringFormat={}{0:0.0}px}" Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="6,0,0,0" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Expander>

                                <!-- 4. Typography & Behavior -->
                                <Expander Header="Typography &amp; Behavior" IsExpanded="False" Style="{StaticResource ModernExpander}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock Text="Font Family" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="FontFamilyCombo" SelectionChanged="FontFamilyCombo_SelectionChanged" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0">
                                                    <ComboBox.Template>
                                                        <ControlTemplate TargetType="ComboBox">
                                                            <Grid>
                                                                <ToggleButton Focusable="false" ClickMode="Press" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                                                    <ToggleButton.Template>
                                                                        <ControlTemplate TargetType="ToggleButton">
                                                                            <Border CornerRadius="8" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1" Padding="8,6">
                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <Path Grid.Column="1" Fill="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Data="M0,0 L4,4 L8,0 Z"/>
                                                                                </Grid>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </ToggleButton.Template>
                                                                </ToggleButton>
                                                                <ContentPresenter IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" Margin="10,0,24,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                                <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                                                    <Grid SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="200">
                                                                        <Border Background="{DynamicResource SurfaceBrush}" BorderThickness="1" BorderBrush="{DynamicResource InputBorderBrush}" CornerRadius="8" Margin="0,4,0,0"/>
                                                                        <ScrollViewer Margin="4,10,4,6">
                                                                            <StackPanel IsItemsHost="True"/>
                                                                        </ScrollViewer>
                                                                    </Grid>
                                                                </Popup>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </ComboBox.Template>
                                                    <ComboBox.ItemContainerStyle>
                                                        <Style TargetType="ComboBoxItem">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                            <Setter Property="Padding" Value="8,6"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ComboBoxItem">
                                                                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}" CornerRadius="6" Margin="2">
                                                                            <ContentPresenter/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </ComboBox.ItemContainerStyle>
                                                </ComboBox>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Font Size" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <Slider x:Name="FontSizeSlider" Minimum="10" Maximum="20" Value="14" Width="120" Style="{StaticResource ModernSlider}" ValueChanged="FontSizeSlider_ValueChanged"/>
                                                    <TextBlock Text="{Binding Value, ElementName=FontSizeSlider, StringFormat={}{0:0}pt}" Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Margin="0,0,0,12">
                                            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="Animations" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="14"/>
                                                        <TextBlock Text="Enable smooth transitions and UI animations" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <CheckBox x:Name="AnimationsCheck" Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource ToggleSwitchStyle}" Checked="AnimationsCheck_Changed" Unchecked="AnimationsCheck_Changed"/>
                                                </Grid>
                                            </Border>

                                            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16,12" Margin="0,0,0,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="Compact Mode" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="14"/>
                                                        <TextBlock Text="Reduce spacing and padding for a denser layout" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <CheckBox x:Name="CompactModeCheck" Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource ToggleSwitchStyle}" Checked="CompactModeCheck_Changed" Unchecked="CompactModeCheck_Changed"/>
                                                </Grid>
                                            </Border>
                                        </StackPanel>

                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </StackPanel>

            <!-- Modern Dialog Overlay -->
            <Border x:Name="DialogOverlay" Visibility="Collapsed" Background="#80000000"
                    CornerRadius="12" IsHitTestVisible="True">
                <Border x:Name="DialogCard" Background="{DynamicResource CardBrush}"
                        CornerRadius="14" MaxWidth="400" Padding="24"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.3" Color="Black"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock x:Name="DialogTitle" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                        <TextBlock x:Name="DialogMessage" FontSize="13" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,20"/>
                        <StackPanel x:Name="DialogButtons" Orientation="Horizontal" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Welcome Overlay -->
            <Border x:Name="WelcomeOverlay" Visibility="Collapsed" Background="Transparent"
                    CornerRadius="12" IsHitTestVisible="True">
                <Border Background="{DynamicResource CardBrush}"
                        CornerRadius="14" MaxWidth="420" Padding="28"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.3" Color="Black"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Compass icon -->
                        <Viewbox Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Canvas Width="32" Height="32">
                                <Ellipse Width="32" Height="32" Stroke="{DynamicResource AccentBrush}" StrokeThickness="2"/>
                                <Polygon Points="16,3 18,14 14,14" Fill="{DynamicResource AccentBrush}"/>
                                <Polygon Points="16,29 18,18 14,18" Fill="{DynamicResource TextTertiaryBrush}"/>
                                <Ellipse Canvas.Left="14" Canvas.Top="14" Width="4" Height="4" Fill="{DynamicResource AccentBrush}"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Welcome to Compass!" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,18"/>
                        <StackPanel Margin="8,0,0,0">
                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,8">
                                <Run FontFamily="Segoe UI Symbol" Text="&#x2328;"/> Press <Run FontWeight="SemiBold">Alt+Space</Run> to open anytime
                            </TextBlock>
                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,8">
                                <Run FontFamily="Segoe UI Symbol" Text="&#x1F50D;"/> Search apps, files, and more
                            </TextBlock>
                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,8">
                                <Run FontFamily="Segoe UI Symbol" Text="&#x1F4AC;"/> Chat with AI for help
                            </TextBlock>
                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,14">
                                <Run FontFamily="Segoe UI Symbol" Text="&#x2699;"/> Type <Run FontWeight="SemiBold">settings</Run> to customize
                            </TextBlock>
                        </StackPanel>
                        <CheckBox x:Name="WelcomeDontShowAgain" Content="Do not show again" Margin="0,0,0,16" Style="{StaticResource ModernCheckBox}"/>
                        <Button Content="Get Started" Click="WelcomeGetStarted_Click" HorizontalAlignment="Center" Style="{StaticResource SettingsButtonStyle}" Padding="24,10"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>
